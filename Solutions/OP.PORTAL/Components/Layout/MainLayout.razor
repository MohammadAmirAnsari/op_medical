@using OP.PORTAL.Helpers
@using MudBlazor
@using OP.PORTAL.Services
@using OP.PORTAL.Components.Shared
@inherits LayoutComponentBase
@inject NavigationManager navigator
@inject NavigationManager NavigationManager
@inject IStringLocalizer<AppResource> localizer

<style>
    .portal-lock-blur {
        filter: blur(10px) grayscale(40%);
        transition: filter 0.3s ease;
        pointer-events: none !important;
        user-select: none !important;
    }
</style>

<MudRTLProvider RightToLeft="@LayoutHelper.RightToLeft">
    <MudThemeProvider Theme="@_theme" IsDarkMode="_isDarkMode" />
    <MudPopoverProvider />
    <MudDialogProvider />
    <MudSnackbarProvider />

@if(isAuthenticated){
    <AuthorizeView>
         <Authorized>

    <MudLayout Class="@dynamic_blur_class">
        <MudAppBar Elevation="1">
            <MudHidden Breakpoint="Breakpoint.MdAndUp">
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Primary" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
            </MudHidden>
            <MudImage Src="oman_logo.png" Alt="Oman Post" Height="40" Elevation="0" Class="ml-3 mr-5 rounded-lg"/>
            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                <MudMenuItem Icon="@Icons.Material.Filled.Home" Label="@localizer["_Home"]" Href="home" Style="width: fit-content; white-space: nowrap;"/>
                <MudMenuItem Icon="@Icons.Material.Filled.PostAdd" IconColor="Color.Success" Label="@localizer["_OvmcRequest"]" Href="request"  Style="width: fit-content; white-space: nowrap;"/>
                <MudMenuItem Icon="@Icons.Material.Filled.History" IconColor="Color.Warning" Label="@localizer["_OvmcHistory"]" Href="history"  Style="width: fit-content; white-space: nowrap;"/> 
                <MudMenuItem Icon="@Icons.Material.Filled.MedicalInformation" IconColor="Color.Error" Label="@localizer["_OvmcAppointment"]" Href="https://services.vfsglobal.com/omn/en/omc/"
                        Target="_blank" Style="width: fit-content; white-space: nowrap;"/>           
            </MudHidden>
            <MudSpacer />                    
            <MudItem>
                <MudButton Color="Color.Success" Target="_blank" Href="@localizer["_HOWTOAPPLYFILE"]">@localizer["_HOWTOAPPLY"]</MudButton>
            </MudItem>
            <LangMenu />
            <MudItem>
                <MudIconButton Icon="@Icons.Material.Filled.Help"  Color="Color.Warning" Href="help" Target="_blank"/> 
            </MudItem>
                        
            <UserMenu />
            @* <MudIconButton Icon="@(DarkLightModeButtonIcon)" Color="Color.Inherit" OnClick="@DarkModeToggle"/> *@  
            
        </MudAppBar>        
        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            <MudDrawer id="nav-drawer" @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
                <NavMenu OnLogout="Logout" />
            </MudDrawer>
        </MudHidden>
        <MudMainContent Class="pt-16 pa-1">
            @Body
        </MudMainContent>
    </MudLayout>
        </Authorized>    
        <Authorizing>
            <PageLoading />
        </Authorizing>
    </AuthorizeView>
}else{
    <PageLoading />
}
</MudRTLProvider>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

    @code {
    #nullable enable
    private bool isAuthenticated = false;
    private bool _rightToLeft = false;
    private bool _drawerOpen = false;
    private bool _isDarkMode = false;
    private MudTheme? _theme = null;

    
    
    private bool _isEmailVerified = true;
    private bool _isModalOpen = false;
    
    private static bool _isLoggingOut = false;
    private IDialogReference? _activeDialog = null;

    private string dynamic_blur_class => (!_isEmailVerified && !IsProfilePage()) ? "portal-lock-blur" : "";

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        NavigationManager.LocationChanged += OnLocationChanged;
        
        CheckCurrentPage();
        
        _isLoggingOut = false;

        _theme = new()
        {
            PaletteLight = _lightPalette,
            PaletteDark = _darkPalette,
            LayoutProperties = new LayoutProperties
            {
                DefaultBorderRadius = "8px"
            }
        };
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (IsProfilePage())
        {
            _isEmailVerified = true;
            if (_activeDialog != null && _isModalOpen)
            {
                Dialog.Close(_activeDialog);
                _isModalOpen = false;
                _activeDialog = null;
            }
        }

        CheckCurrentPage();
        
        await InvokeAsync(async () => 
        {
            await CheckEmailVerificationStatus();
            StateHasChanged();
        });
    }

    private void CheckCurrentPage()
    {
        if (IsProfilePage())
        {
            _isEmailVerified = true;
            _isModalOpen = false;
        }
    }

    private bool IsProfilePage()
    {
        string relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        return string.Equals(relativePath, "profile", StringComparison.OrdinalIgnoreCase);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isLoggingOut) return;

        isAuthenticated = await TokenHelper.IsAuthenticated();
        if (!isAuthenticated)
        {
            navigator.NavigateTo($"");
        }
        else if (firstRender)
        {
            await CheckEmailVerificationStatus();
        }

        if (firstRender)
        {
            StateHasChanged();
        }

    }

    private async Task CheckEmailVerificationStatus()
    {
        if (_isLoggingOut || IsProfilePage()) return;

        try
        {
            var profile = await SponsorService.GetProfile();

            if (profile != null)
            {
                _isEmailVerified = profile.IsEmailVerified;

                if (!_isEmailVerified && !_isModalOpen)
                {
                    await InvokeAsync(async () => await OpenGlobalLockModal(profile));
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Global Interceptor Exception: {ex.Message}");
        }
    }

    private async Task OpenGlobalLockModal(SponsorProfile profile)
    {
        if (_isLoggingOut || IsProfilePage()) return;
        
        _isModalOpen = true;
        StateHasChanged();

        var parameters = new DialogParameters<EmailRestrictionModal>
        {
            { x => x.SponsorId, profile.Id },
            { x => x.UserEmail, profile.Email },
            { x => x.UserName, profile.Name }
        };

        var options = new DialogOptions 
        { 
            CloseOnEscapeKey = false, 
            CloseButton = false, 
            BackdropClick = false, 
            MaxWidth = MaxWidth.Small, 
            FullWidth = true 
        };

        _activeDialog = await Dialog.ShowAsync<EmailRestrictionModal>("Verification Required", parameters, options);
        var result = await _activeDialog.Result;
        
        _isModalOpen = false;
        _activeDialog = null;

        if (result.Canceled)
        {
            await Logout();
        }
    }

    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void DarkModeToggle()
    {
        _isDarkMode = !_isDarkMode;
    }

    private readonly PaletteLight _lightPalette = new()
    {
        Primary = "#41b6e6",             // Your main color
        Secondary = "#00acc1",           // Complementary
        AppbarBackground = "#ffffff",    // White appbar
        AppbarText = "#212121",          // Dark text
        Background = "#f0f2f5",          // Light page background
        Surface = "#ffffff",              // Cards and surfaces
        DrawerBackground = "#ffffff",
        DrawerText = "#212121",
        DrawerIcon = "#41b6e6",
        TextPrimary = "#212121",
        TextSecondary = "#555555",
        ActionDefault = "#41b6e6",
        ActionDisabled = "#9e9e9e",
        Success = "#4caf50",
        Info = "#2196f3",
        Warning = "#ff9800",
        Error = "#f44336"
    };

    private readonly PaletteDark _darkPalette = new()
    {
        Primary = "#41b6e6",             // Main color stays same
        Secondary = "#00acc1",
        AppbarBackground = "#1e1e1e",    // Dark appbar
        AppbarText = "#ffffff",          // White text
        Background = "#121212",          // Dark background
        Surface = "#1e1e1e",             // Cards/surfaces
        DrawerBackground = "#1b1b1b",
        DrawerText = "#ffffff",
        DrawerIcon = "#41b6e6",
        TextPrimary = "#ffffff",
        TextSecondary = "#bbbbbb",
        ActionDefault = "#41b6e6",
        ActionDisabled = "#555555",
        Success = "#4caf50",
        Info = "#2196f3",
        Warning = "#ffb74d",
        Error = "#ef5350"
    };

    public string DarkLightModeButtonIcon => _isDarkMode switch
    {
        true => Icons.Material.Rounded.AutoMode,
        false => Icons.Material.Outlined.DarkMode,
    };

    private async Task Logout()
    {
        _isLoggingOut = true;
        
        await TokenHelper.RemoveTokenAsync();

        isAuthenticated = false;
        _isModalOpen = false;

        _activeDialog = null;
        navigator.NavigateTo("", forceLoad: true);
    }
}


