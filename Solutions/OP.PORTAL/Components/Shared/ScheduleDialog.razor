<MudDialog>
    <TitleContent>
        @localizer.Html("_ScheduleAppointmentMessage")
    </TitleContent>
    <DialogContent>
        @localizer.Html("_ScheduleAppointmentDetails")
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" Href="@($"https://omanpost.om?t={RequestUrnNumber}")" Target="_blank" OnClick="Cancel">@localizer["_ScheduleNow"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public string RequestUrnNumber { get; set; }

    void Cancel() => MudDialog.Cancel();
}