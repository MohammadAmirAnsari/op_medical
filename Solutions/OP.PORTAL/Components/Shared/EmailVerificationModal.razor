@using MudBlazor

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" />
            <MudText Typo="Typo.h6">Registration Successful</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body1" Class="mb-3">
            Your account has been successfully created and your phone number has been verified!
        </MudText>
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-2">
            We've sent a secure <b>Magic Verification Link</b> to your email address (<b>@UserEmail</b>).
            You can use the app, but please verify your email by checking your inbox for billing and profile updates.
        </MudAlert>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Login" OnClick="Close" FullWidth="true">
            Proceed To Login
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; }

    [Parameter] public string UserEmail { get; set; }

    private void Close() => MudDialog.Close(MudBlazor.DialogResult.Ok(true));
}
