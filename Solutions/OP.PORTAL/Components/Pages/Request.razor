@page "/request"
@page "/request/{encidt}"

<MudForm @ref="_form" Disabled="@_submitted">
    <MudCard Outlined="true" Elevation="2" Class="pa-4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6" GutterBottom="true">@localizer.Html("_OvmcRequestMessage")</MudText>
                <MudText Typo="Typo.body1" Class="mb-2">@localizer.Html("_OvmcRequestDetails")</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent Style="border: 1px solid lightgray; border-radius: 10px;" Class="ma-1">
            <MudStack StretchItems="StretchItems.All" Wrap="Wrap.Wrap" Row="true" AlignItems="AlignItems.Start">
                <MudPaper Class="pa-3" Elevation="2">
                        <MudTextField 
                                Autofocus="true"
                                @bind-Value="model.MolWorkPermitNo" 
                                For="@(() => model.MolWorkPermitNo)"
                                Label="@localizer["_MolWorkPermitNo"]"
                                HelperText="@localizer["_MolWorkPermitNoHelperText"]"
                                Placeholder="@localizer["_MolWorkPermitNoPlaceholder"]"
                                Variant="Variant.Outlined"
                                ShrinkLabel 
                                Margin="Margin.Dense"
                                Class="text-uppercase mb-3"
                                Immediate="false"
                                Validation="OvmcValidator.OnlyNumber(8, 8)"
                                OnBlur="@(() => OvmcValidator.UppercaseField(model, nameof(model.MolWorkPermitNo)))"
                                OnlyValidateIfDirty="true"/>

                       <MudSelect
                                Value="model.Country"
                                ValueChanged="@(async (string v) => await OnCountryChanged(v))"
                                For="@(() => model.Country)"
                                Label="@localizer["_Country"]"
                                HelperText="@localizer["_CountryHelperText"]"
                                Placeholder="@localizer["_CountryPlaceholder"]"
                                AdornmentIcon="@Icons.Material.Filled.Flag"                             
                                AdornmentColor="Color.Primary"
                                Variant="Variant.Outlined"
                                Dense="true" ShrinkLabel 
                                     Class="text-uppercase mb-3"
                                Margin="Margin.Dense">
                                @foreach (var item in _countries)
                                {
                                    <MudSelectItem Value="@item">
                                        @item
                                    </MudSelectItem>
                                }
                            </MudSelect>
                                     
                    <MudAutocomplete T="string" SearchFunc="@cityFilter"
                                @bind-Value="model.City" 
                                For="@(() => model.City)"
                                Label="@localizer["_City"]"
                                HelperText="@localizer["_CityHelperText"]"
                                Placeholder="@localizer["_CityPlaceholder"]"
                                     AdornmentIcon="@Icons.Material.Filled.Search"
                                AdornmentColor="Color.Primary"
                                Variant="Variant.Outlined"
                                Dense="true" ShrinkLabel
                                Clearable="true"
                                Modal="true"
                                Class="text-uppercase mb-3" 
                               Margin="Margin.Dense">
                        @foreach (var item in _cities)
                        {
                            <MudSelectItem Value="@item">
                                @item
                            </MudSelectItem>
                        }
                    </MudAutocomplete>

                        <MudSelect 
                                @bind-Value="model.VisaType" 
                                For="@(() => model.VisaType)"
                                Label="@localizer["_VisaType"]"
                                HelperText="@localizer["_VisaTypeHelperText"]"
                                Placeholder="@localizer["_VisaTypePlaceholder"]"
                                AdornmentIcon="@Icons.Material.Filled.AirplaneTicket"
                                AdornmentColor="Color.Primary"
                                Variant="Variant.Outlined"
                                Dense="true" ShrinkLabel 
                                Class="text-uppercase mb-3"
                                Margin="Margin.Dense">
                                @foreach (var item in _visatypes)
                                {
                                    <MudSelectItem Value="@item.Name">
                                        @item.Name
                                    </MudSelectItem>
                                }
                            </MudSelect>  

                        <MudTextField 
                                @bind-Value="model.PassportNo" 
                                For="@(() => model.PassportNo)"
                                Label="@localizer["_PassportNo"]"
                                HelperText="@localizer["_PassportNoHelperText"]"
                                Placeholder="@localizer["_PassportNoPlaceholder"]"
                                  Variant="@((new[]{OvmcRequestStatus.SUBMITTED,OvmcRequestStatus.INPROCESS,OvmcRequestStatus.COMPLETED}.Contains(model.RequestStatus)) ? Variant.Filled : Variant.Outlined)"
                                ShrinkLabel 
                                Margin="Margin.Dense"
                                  Readonly="@((new[]{OvmcRequestStatus.SUBMITTED,OvmcRequestStatus.INPROCESS,OvmcRequestStatus.COMPLETED}.Contains(model.RequestStatus)))"
                                Adornment="Adornment.Start"
                                  AdornmentIcon="@((new[]{OvmcRequestStatus.SUBMITTED,OvmcRequestStatus.INPROCESS,OvmcRequestStatus.COMPLETED}.Contains(model.RequestStatus)) ? Icons.Material.Filled.Lock : "")"
                                  AdornmentColor="@((new[]{OvmcRequestStatus.SUBMITTED,OvmcRequestStatus.INPROCESS,OvmcRequestStatus.COMPLETED}.Contains(model.RequestStatus)) ? Color.Error : Color.Primary)"
                                Immediate="false"                                        
                                Validation="@(new Func<string, string>(OvmcValidator.NoArabic))"
                                OnBlur="@(() => OvmcValidator.UppercaseField(model, nameof(model.PassportNo)))"
                                OnlyValidateIfDirty="true"/>    
                 </MudPaper>
                <MudPaper Class="pa-3" Elevation="2">
                    <MudTextField 
                                @bind-Value="model.GivenName" 
                                For="@(() => model.GivenName)"
                                Label="@localizer["_GivenName"]"
                                HelperText="@localizer["_GivenNameHelperText"]"
                                Placeholder="@localizer["_GivenNamePlaceholder"]"
                                Variant="Variant.Outlined"
                                ShrinkLabel 
                                Margin="Margin.Dense"
                                Immediate="false"  
                                Class="text-uppercase mb-5"
                                Validation="@(new Func<string, string>(OvmcValidator.NoArabic))"
                                OnBlur="@(() => OvmcValidator.UppercaseField(model, nameof(model.GivenName)))"
                                OnlyValidateIfDirty="true" />
                    
                    <MudTextField 
                            @bind-Value="model.Surname" 
                            For="@(() => model.Surname)"
                            Label="@localizer["_Surname"]"
                            HelperText="@localizer["_SurnameHelperText"]"
                            Placeholder="@localizer["_SurnamePlaceholder"]"
                            Variant="Variant.Outlined"
                            ShrinkLabel 
                            Margin="Margin.Dense"
                            Immediate="false"     
                            Class="text-uppercase mb-3"
                            Validation="@(new Func<string, string>(OvmcValidator.NoArabic))"
                            OnBlur="@(() => OvmcValidator.UppercaseField(model, nameof(model.Surname)))"
                            OnlyValidateIfDirty="true" />

                    <MudDatePicker @bind-Date="model.PassportIssueDate" Editable="true"
                                   For="@(() => model.PassportIssueDate)"
                                   Label="@localizer["_PassportIssueDate"]"
                                   HelperText="@localizer["_DateOfBirthHelperText"]"
                                   Placeholder="@localizer["_PassportIssueDatePlaceholder"]"
                                   Variant="Variant.Outlined"
                                   DateFormat="@OvmcFormat.DATEFORMAT"
                                   ShrinkLabel
                                   OpenTo="OpenTo.Year"
                                   Validation="@(new Func<DateTime?, string>(ValidateIssueDate))"
                                   MaxDate="DateTime.Today.AddDays(-1)"
                                   Margin="Margin.Dense" />

                    <MudDatePicker  @bind-Date="model.PassportExpiryDate" Editable="true"
                                For="@(() => model.PassportExpiryDate)"
                                Label="@localizer["_PassportExpiryDate"]"
                                   HelperText="@localizer["_DateOfBirthHelperText"]"
                                Placeholder="@localizer["_PassportExpiryDatePlaceholder"]"
                                Variant="Variant.Outlined"
                                DateFormat="@OvmcFormat.DATEFORMAT"
                                ShrinkLabel 
                                OpenTo="OpenTo.Year"
                                   Validation="@(new Func<DateTime?, string>(ValidateExpiryDate))"
                                Class="text-uppercase mb-3"
                                MinDate="DateTime.Today.AddDays(180)"
                                Margin="Margin.Dense"/>

                    <MudAutocomplete T="string"
                                @bind-Value="model.PassportIssuePlace" 
                                For="@(() => model.PassportIssuePlace)"
                                Label="@localizer["_PassportIssuePlace"]"
                                HelperText="@localizer["_PassportIssuePlaceHelperText"]"
                                Placeholder="@localizer["_PassportIssuePlacePlaceholder"]"
                                AdornmentIcon="@Icons.Material.Filled.Search"
                                AdornmentColor="Color.Primary"
                                Variant="Variant.Outlined"
                                Dense="true" ShrinkLabel 
                                Margin="Margin.Dense"
                                Clearable="true"
                                Modal="true" 
                                ShowProgressIndicator="true"
                                MinCharacters="3"
                                DebounceInterval="1000"
                                Class="text-uppercase mb-3"
                                ResetValueOnEmptyText="true"
                                OpenOnFocus="false"
                                SearchFunc="SearchPlacesAsync">
                    </MudAutocomplete>

                     
                </MudPaper>
                <MudPaper Class="pa-3" Elevation="2">
                    <MudDatePicker 
                                @bind-Date="model.DateOfBirth" 
                                For="@(() => model.DateOfBirth)"
                                Label="@localizer["_DateOfBirth"]"
                                HelperText="@localizer["_DateOfBirthHelperText"]"
                                Placeholder="@localizer["_DateOfBirthPlaceholder"]"
                                Variant="Variant.Outlined"
                                Editable="true"
                                DateFormat="@OvmcFormat.DATEFORMAT"
                                ShrinkLabel 
                                OpenTo="OpenTo.Year"
                                Validation="@(new Func<DateTime?, string>(ValidateBirthDate))"
                                Class="text-uppercase mb-3"
                                MaxDate="DateTime.Today.AddYears(-18)"
                                MinDate="DateTime.Today.AddYears(-60)"
                                Margin="Margin.Dense"/>

                    <MudSelect 
                                @bind-Value="model.Gender" 
                                For="@(() => model.Gender)"
                                Label="@localizer["_Gender"]"
                                HelperText="@localizer["_GenderHelperText"]"
                                Placeholder="@localizer["_GenderPlaceholder"]"
                                AdornmentIcon="@Icons.Material.Filled.SupervisedUserCircle" 
                                AdornmentColor="Color.Primary"
                                Variant="Variant.Outlined"
                                Dense="true" ShrinkLabel 
                                Class="text-uppercase mb-3"
                                Margin="Margin.Dense">
                                @foreach (var item in _genders)
                                {
                                    <MudSelectItem Value="@item.Name">
                                        @item.Name
                                    </MudSelectItem>
                                }
                            </MudSelect>  

                    <MudSelect 
                                @bind-Value="model.MaritalStatus" 
                                For="@(() => model.MaritalStatus)"
                                Label="@localizer["_MaritalStatus"]"
                                HelperText="@localizer["_MaritalStatusHelperText"]"
                                Placeholder="@localizer["_MaritalStatusPlaceholder"]"
                                AdornmentIcon="@Icons.Material.Filled.SupervisedUserCircle"
                                AdornmentColor="Color.Primary"
                                Variant="Variant.Outlined"
                                Dense="true" ShrinkLabel 
                                Class="text-uppercase mb-3"
                                Margin="Margin.Dense">
                                @foreach (var item in _maritalstatus)
                                {
                                    <MudSelectItem Value="@item.Name">
                                        @item.Name
                                    </MudSelectItem>
                                }
                            </MudSelect>

                    <MudTextField 
                                @bind-Value="model.Email" 
                                For="@(() => model.Email)"
                                Label="@localizer["_ApplicantEmail"]"
                                HelperText="@localizer["_EmailHelperText"]"
                                Placeholder="@localizer["_EmailPlaceholder"]"
                                Variant="Variant.Outlined"
                                ShrinkLabel 
                                Margin="Margin.Dense"
                                Immediate="false"    
                                Class="text-uppercase mb-3"                         
                                Validation="@(new Func<string, string>(OvmcValidator.Email))"
                                OnBlur="@(() => OvmcValidator.UppercaseField(model, nameof(model.Email)))"
                                OnlyValidateIfDirty="true"/>

                    <MudTextField InputType="InputType.Number"
                                @bind-Value="model.PhoneNo" 
                                For="@(() => model.PhoneNo)"
                                Label="@localizer["_ApplicantPhoneNo"]"
                                HelperText="@localizer["_PhoneNoHelperText"]"
                                Placeholder="@localizer["_PhoneNoPlaceholder"]"
                                Variant="Variant.Outlined"
                                ShrinkLabel 
                                Margin="Margin.Dense"
                                Immediate="false"                                                                                                
                                Validation="@(new Func<string, string>(OvmcValidator.NoArabic))"
                                OnBlur="@(() => OvmcValidator.UppercaseField(model, nameof(model.PhoneNo)))"
                                OnlyValidateIfDirty="true"/>
                </MudPaper>
            </MudStack>
        </MudCardContent>
        <MudCardActions>
            <MudGrid Spacing="1">
                    <MudItem xs="12" sm="4">
                        <MudCheckBox Required="true" RequiredError="" @bind-Value="model.IsTnCAccepted" For="@(() => model.IsTnCAccepted)" Color="Color.Secondary">
                        @localizer.Html("_AgreeTo") <MudLink Href="javascript:void(0)" Class="link-custom-class" @onclick="OnLabelClick">@localizer.Html("_RequestAgreeTerms")</MudLink>
                        </MudCheckBox>
                    </MudItem>
                    <MudItem xs="12" sm="3"></MudItem>
                    <MudItem xs="12" sm="4">
                        <MudButton StartIcon="@Icons.Material.Filled.Payments" Variant="Variant.Filled" Color="Color.Primary" DropShadow="false" Class="ml-1 mr-1" OnClick="Submit">@localizer.Html("_Proceed")</MudButton>
                        @if(!string.IsNullOrEmpty(encidt)){
                            <MudButton StartIcon="@Icons.Material.Filled.Refresh" Variant="Variant.Outlined" Color="Color.Default" DropShadow="false" Class="ml-1 mr-1" OnClick="@(()=> RefreshData())">@localizer.Html("_Refresh")</MudButton>
                        }
                        <MudButton StartIcon="@Icons.Material.Filled.SettingsBackupRestore" Variant="Variant.Outlined" Color="Color.Default" DropShadow="false" Class="ml-1 mr-1" OnClick="@(()=> ResetRequestAsync())">@localizer.Html("_Reset")</MudButton>                 
                    </MudItem>
            </MudGrid>
        </MudCardActions>
    </MudCard>
</MudForm>
<style>
    .my-custom-class {
        backdrop-filter: blur(1px);
    }
    .link-custom-class {
        color: var(--mud-palette-primary);
        cursor: pointer;
    }
</style>
@code {
    private MudForm _form;
    private bool _submitted = false;
    OvmcRequest model = new ();

    [Parameter] public string encidt { get; set; }
    private List<GeneralMaster> _gmRecords = new();
    private List<GeneralMaster> _genders = new();
    private List<GeneralMaster> _visatypes = new();
    private List<GeneralMaster> _maritalstatus = new();
    private List<string> _countries = new();
    private List<string> _cities = new();

    private string ValidateIssueDate(DateTime? date)
    {
        if (date != null && date > DateTime.Today.AddDays(-1))
            return "Issue Date cannot be in the future";
        return null; // No error
    }

    private void OnLabelClick()
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = false,
            CloseButton = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };


        var dialog = Dialog.ShowAsync<Terms>("OMAN POST TERMS AND CONDITIONS (OVMC)", options);

    }


    private async Task<IEnumerable<string>> cityFilter(string value, CancellationToken token)
    {
        // In real life use an asynchronous function for fetching data from an api.


        // if text is null or empty, don't return values (drop-down will not open)
        if (string.IsNullOrEmpty(value))
            return new string[0];
        return _cities.Where(x => x.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }
    private string ValidateExpiryDate(DateTime? date)
    {
        if (date != null && date < DateTime.Today.AddDays(180))
            return "Expiry Date cannot be less than 6 months from today";
        return null; // No error
    }

    private string ValidateBirthDate(DateTime? date)
    {
        if (date != null && (date > DateTime.Today.AddYears(-18) || date < DateTime.Today.AddYears(-60)))
            return "You must be between 18 and 60 years old";
        return null; // No error
    }

    protected override async Task OnInitializedAsync()
    {
        _gmRecords = await GeneralMasterService.GetAllAsync();
        _genders = _gmRecords.Where(x => x.MasterType == MasterTypes.GENDER).ToList();
        _visatypes = _gmRecords.Where(x => x.MasterType == MasterTypes.VISATYPE).ToList();
        _maritalstatus = _gmRecords.Where(x => x.MasterType == MasterTypes.MARITALSTATUS).ToList();
        _countries = _gmRecords.Where(x => x.MasterType == MasterTypes.COUNTRY).Select(c=>c.Name).ToList();

        if(!string.IsNullOrEmpty(encidt)){
            OvmcRequest? editModel = await OvmcService.GetAsync(encidt);
            if(editModel != null){
                model = editModel;
                model.IsTnCAccepted = false;
                _cities = _gmRecords.Where(x => x.MasterType == MasterTypes.CITY && x.ParentName != null && x.ParentName == model.Country).Select(c => c.Name).ToList();
            }
        }
    }

    public async Task OnCountryChanged(string countryName)
    {
        model.Country = countryName;
        model.City = ""; // reset city
        _cities.Clear();

        if (countryName != null)
            _cities = _gmRecords.Where(x => x.MasterType == MasterTypes.CITY && x.ParentName != null && x.ParentName == countryName).Select(c => c.Name).ToList();

        StateHasChanged();
    }

    public async Task<IEnumerable<string>> SearchPlacesAsync(string q, CancellationToken token)
    {
        return await LocationService.SearchPlacesAsync(q);
    }

    public async Task<IEnumerable<string>> SearchCountryCitesAsync(string q, CancellationToken token)
    {
        return await CountriesNowService.GetCountryCitiesAsync(q);
    }

    public async Task<IEnumerable<string>> SearchCountryAsync(string q, CancellationToken token)
    {
        return await CountriesNowService.GetCountriesAsync();
    }

    private async Task Submit()
    {
        await _form.ValidateAsync();

        if (_form.IsValid)
        {
            bool? confirm = await Dialog.ShowMessageBoxAsync(
                localizer["_ReviewAndConfirm"],
                "",
                yesText: localizer["_Confirm"],
                cancelText: localizer["_Review"],
                options: new DialogOptions { MaxWidth = MaxWidth.Small, BackgroundClass = "my-custom-class" });

            if (confirm == true)
            {
                _submitted = true;   // 🔒 disables form
                StateHasChanged();
                if (model.Id == 0)
                {
                    model.RequestStatus = OvmcRequestStatus.SUBMITTED;
                }

                int rec = await OvmcService.AddAsync(model);
                if(rec > 0) {
                    if(model.PaymentStatus != OvmcPaymentStatus.SUCCESS){                        
                        bool? confirm1 = await Dialog.ShowMessageBoxAsync(
                            localizer["_ProceedToPayment"],
                            "",
                            yesText: localizer["_PayNow"],
                            cancelText: localizer["_PayLater"],
                            options: new DialogOptions { MaxWidth = MaxWidth.Small, BackgroundClass = "my-custom-class" });

                            if (confirm1 == true)
                            {
                                var payment = await PaymentService.InitiatePaymentAsync(model.Id);
                                if(payment != null){
                                    await jsRuntime.InvokeVoidAsync("openBankPayment", (string) payment.paymentUrl, (string) payment.encRequest, (string) payment.accessCode);
                                } else {
                                    Snackbar.Add(localizer.Html("_PaymentFailedToInitiate"), Severity.Error);
                                }

                                Snackbar.Add(localizer.Html("_PaymentRedirectionMessage"), Severity.Normal, (options) =>
                                {
                                    options.HideTransitionDuration = 10000; 
                                    options.ShowCloseIcon = false;
                                    options.CloseAfterNavigation = true;
                                });

                                await Task.Delay(10000);
                                navigator.NavigateTo("history");
                                return;
                            }else{
                                Snackbar.Add(localizer.Html("_RequestSubmittedSuccessMessage"), Severity.Success);
                                navigator.NavigateTo("home");
                                return;
                            }
                    }else{
                        Snackbar.Add(localizer.Html("_RequestSubmittedSuccessMessage"), Severity.Success);
                        navigator.NavigateTo("home");
                        return;
                    }
                }
                else Snackbar.Add(localizer.Html("_RequestSubmittedSErrorMessage"), Severity.Error);

                await ResetRequestAsync();
            }        
        }
    }

    private async Task ResetRequestAsync(){  
        _submitted = false;
        model = new ();
        StateHasChanged();
        await _form.ResetAsync();
        navigator.NavigateTo("request");
    }

    private async Task RefreshData(){ 
        _submitted = false;
        StateHasChanged();
        await _form.ResetAsync();
        if(!string.IsNullOrEmpty(encidt)){
            OvmcRequest? editModel = await OvmcService.GetAsync(encidt);
            if(editModel != null){
                model = editModel;
                model.IsTnCAccepted = false;
                _cities = await CountriesNowService.GetCountryCitiesAsync(model.Country);
            }
       }
    }
}
