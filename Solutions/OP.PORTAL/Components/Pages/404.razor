@page "/resource-not-found-404"
@layout Layout.OpenLayout

<MudPaper Elevation="2" Class="pa-6 rounded-2xl">
    <MudGrid Class="mt-2 mb-2" Justify="Justify.Center" Spacing="3">
        <MudText Typo="Typo.h3" GutterBottom Color="Color.Error">
                @localizer.Html("_PageNotFound404Message")
        </MudText>

        <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true"
                    OnClick="GoBack" StartIcon="@Icons.Material.Filled.ArrowBack">
            @localizer["_GoBack"]
        </MudButton>
    </MudGrid>
</MudPaper>

@code {
    private void GoBack()
    {
        navigator.NavigateTo("", forceLoad: false);
    }
}